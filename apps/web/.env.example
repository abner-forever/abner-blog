# =============================================
# web 环境变量配置
# 复制此文件为 .env.local 或 .env
# =============================================

# API 配置
VITE_API_BASE_URL=/api
VITE_UPLOAD_URL=/assets

# 应用配置
VITE_APP_TITLE=Modern Blog
VITE_APP_DESCRIPTION=我的技术博客

# 腾讯云验证码（TJCaptcha）可选外观：见 https://cloud.tencent.com/document/product/1110/36841
# 弹窗整体缩放，对应文档 .tcaptcha-transform 的 scale，例如 0.92
# VITE_TENCENT_CAPTCHA_SCALE=1
# 是否显示加载中（true/false）；不配则使用 SDK 默认
# VITE_TENCENT_CAPTCHA_LOADING=true
