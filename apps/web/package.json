{
  "name": "@abner-blog/web",
  "private": true,
  "version": "0.0.0-development",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @abner-blog/env-tool run build",
    "dev": "vite",
    "dev:serve": "node server.js",
    "build": "tsc -b && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "preview": "vite preview",
    "generate:api": "orval --config orval.config.ts && prettier --write \"src/services/generated\" && node scripts/report-api-changes.mjs",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "@abner-blog/env-tool": "workspace:*",
    "@abner-blog/upload": "workspace:*",
    "@abner-blog/utils": "workspace:*",
    "@ant-design/icons": "^6.1.0",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-query": "^5.90.21",
    "antd": "^6.3.1",
    "axios": "^1.9.0",
    "browser-image-compression": "^2.0.2",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "esbuild-register": "^3.6.0",
    "express": "^5.2.1",
    "framer-motion": "10.18.0",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "md-editor-rt": "^4.21.2",
    "postcss-px-to-viewport": "^1.1.1",
    "postcss-pxtorem": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^15.1.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^11.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^29.0.0",
    "less": "^4.3.0",
    "orval": "^8.5.3",
    "postcss-preset-env": "^10.1.6",
    "semantic-release": "^22.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.0"
  },
  "release": {
    "extends": "semantic-release-monorepo",
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git"
    ]
  }
}
