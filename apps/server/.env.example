# =============================================
# Server 环境变量配置
# 复制此文件为 .env 并填写实际值
# =============================================

# JWT 配置（用户站 access + refresh 双令牌）
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Access JWT 有效期（如 15m、1h）
JWT_ACCESS_EXPIRES_IN=15m
# Refresh JWT 与 Redis 会话 TTL（如 30d、7d）
JWT_REFRESH_EXPIRES_IN=30d
# 已废弃：旧版单 token 曾用 JWT_EXPIRES_IN，请改用 JWT_ACCESS_EXPIRES_IN
# JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=900000

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=blog

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 邮件配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@qq.com
SMTP_PASS=
SMTP_FROM="Modern Blog" <your-email@qq.com>

# AI 日程 API
MINIMAX_API_KEY=
OPENAI_API_MODEL=MiniMax-M2.7
# MiniMax API 根地址（不要带末尾 /）
# - 国际控制台 (platform.minimax.io) 密钥：默认 https://api.minimax.io，可不配
# - 国内控制台 (platform.minimaxi.com) 密钥：必须配，否则常见 401 / invalid api key (2049)
# MINIMAX_API_BASE=https://api.minimaxi.com
# 旧域名（仅兼容遗留）：https://api.minimax.chat

# AI 聊天排错：为 1 时写入 logs/ai-stream-debug-*.log（MiniMax 每条 SSE 结构摘要）；Nest 日志含前 8 条块、解析失败、stream_close、invoke 空正文摘要
# AI_CHAT_DEBUG=

# 技能向量匹配（与知识库共用 CHROMA_URL + MiniMax embedding；Chroma collection: skill_vectors）
# 用户「已激活」技能数 >= SKILL_VECTOR_MIN_ACTIVE 时，按当前用户消息检索 Top SKILL_VECTOR_TOP_K 再注入系统提示；否则仍合并全部已激活技能。
# CHROMA_URL=http://localhost:8000
# SKILL_VECTOR_MIN_ACTIVE=4
# SKILL_VECTOR_TOP_K=4

# AI 联网搜索（CHAT 路径下 MCP「网页检索」或直连 API）：二选一即可，优先 Tavily
# Tavily：https://tavily.com
# TAVILY_API_KEY=
# Brave Search API：https://api.search.brave.com
# BRAVE_SEARCH_API_KEY=

# 分片上传体积上限（字节，可选）。视频默认 2 GiB、通用文件默认 500 MiB
# VIDEO_MAX_SIZE=2147483648
# FILE_MAX_SIZE=524288000

# 应用配置
NODE_ENV=development
PORT=8080
# 对外可访问的 API 根地址（不含尾部斜杠；不要带 /api 后缀）。用于 MCP 目录中本机 GitHub MCP 等默认 URL 拼接。
# 生产示例：https://api.example.com
# PUBLIC_API_BASE_URL=http://127.0.0.1:8080
# 前端站点地址（MCP OAuth 授权页回跳用）
# 示例：https://app.example.com
WEB_URL=http://localhost:3000

# CORS（多个域名用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# 腾讯云验证码（天御图形验证 Web 2.0）— 四项均配置后，密码登录与发送邮箱验证码前需完成滑块验证
# 密钥见：https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
# 验证码控制台「验证管理」CaptchaAppId（数字）
TENCENT_CAPTCHA_APP_ID=
# 同页 AppSecretKey（仅服务端票据校验，勿泄露）
TENCENT_CAPTCHA_APP_SECRET_KEY=
# 套餐过期等需整站关闭滑块时：TENCENT_CAPTCHA_DISABLED=true（或 TENCENT_CAPTCHA_ENABLED=false）
# TENCENT_CAPTCHA_DISABLED=true
# TENCENT_CAPTCHA_ENABLED=false

# Open-Meteo / 地理编码 HTTP 超时（毫秒），默认 15000，范围 5000–60000
# WEATHER_HTTP_TIMEOUT_MS=20000

# 和风天气 JWT 认证（Ed25519）
# API Host（控制台-设置中查看，格式如 abc1234xyz.def.qweatherapi.com）
QWEATHER_API_HOST=
# Ed25519 私钥（-----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----）
QWEATHER_PRIVATE_KEY=
# Project ID（控制台-项目管理中查看）
QWEATHER_PROJECT_ID=
# Key ID / Credential ID（创建 JWT 凭据后生成）
QWEATHER_KEY_ID=
