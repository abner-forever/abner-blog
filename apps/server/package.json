{
  "name": "@abner-blog/server",
  "version": "0.0.0-development",
  "description": "abner-blog server",
  "author": "abner",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "sh -c 'pkill -f \"@nestjs/cli/bin/nest.js start --watch\" 2>/dev/null || true; pids=$(lsof -tiTCP:8080 -sTCP:LISTEN); [ -z \"$pids\" ] || kill -9 $pids; nest start --watch'",
    "start": "nest start",
    "start:dev": "sh -c 'pkill -f \"@nestjs/cli/bin/nest.js start --watch\" 2>/dev/null || true; pids=$(lsof -tiTCP:8080 -sTCP:LISTEN); [ -z \"$pids\" ] || kill -9 $pids; nest start --watch'",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "webpack": "webpack --config webpack.config.js",
    "webpack:hmr": "webpack --config webpack-hmr.config.js",
    "semantic-release": "semantic-release",
    "init:topics": "ts-node -r tsconfig-paths/register src/scripts/init-topics.ts"
  },
  "dependencies": {
    "@langchain/community": "^1.1.25",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^11.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.1",
    "@nestjs/platform-socket.io": "^11.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^11.1.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^10.0.0",
    "ajv": "^6.12.6",
    "ajv-keywords": "^3.5.2",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^7.4.3",
    "langchain": "^1.2.37",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.1",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "1.1.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.1",
    "run-script-webpack-plugin": "^0.2.0",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "tencentcloud-sdk-nodejs-captcha": "^4.1.191",
    "typeorm": "^0.3.20",
    "uuid": "^11.1.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^11.0.2",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/pdf-parse": "^1.1.5",
    "@types/sanitize-html": "^2.13.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "semantic-release": "^22.0.7",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "release": {
    "extends": "semantic-release-monorepo",
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git"
    ]
  }
}
